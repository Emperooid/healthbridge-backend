generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum RecordStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  FILE_UPLOAD
  FILE_ACCESS
  SHARE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  LAB_REVIEW
  PROCEDURE
  EMERGENCY
}

enum ShareLinkStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum VisitStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LabOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  role      Role     @default(PATIENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  patient       Patient?
  doctor        Doctor?
  auditLogs     AuditLog[]
  notifications Notification[]
  shareGrants   ShareGrant[]   @relation("GrantedTo")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Hospital {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  email     String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors       Doctor[]
  patients      Patient[]
  records       MedicalRecord[]
  appointments  Appointment[]
  departments   Department[]
  visits        Visit[]
  prescriptions Prescription[]
  labOrders     LabOrder[]

  @@map("hospitals")
}

model Department {
  id          String   @id @default(uuid())
  hospitalId  String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  visits   Visit[]

  @@map("departments")
}

model Doctor {
  id             String   @id @default(uuid())
  userId         String   @unique
  hospitalId     String
  specialization String?
  licenseNumber  String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital         Hospital        @relation(fields: [hospitalId], references: [id])
  records          MedicalRecord[]
  appointments     Appointment[]
  assignedPatients Patient[]       @relation("AssignedDoctor")
  visits           Visit[]
  prescriptions    Prescription[]
  labOrders        LabOrder[]

  @@map("doctors")
}

model Patient {
  id               String    @id @default(uuid())
  userId           String    @unique
  hospitalId       String
  assignedDoctorId String?
  globalPatientId  String    @unique @default(uuid())
  dateOfBirth      DateTime?
  gender           String?
  bloodType        String?
  allergies        String[]
  emergencyContact String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital        Hospital       @relation(fields: [hospitalId], references: [id])
  assignedDoctor  Doctor?        @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  records         MedicalRecord[]
  appointments    Appointment[]
  shareLinks      ShareLink[]
  shareGrants     ShareGrant[]   @relation("PatientGrants")
  visits          Visit[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]

  @@map("patients")
}

model MedicalRecord {
  id           String       @id @default(uuid())
  patientId    String
  doctorId     String
  hospitalId   String
  title        String
  description  String
  diagnosis    String?
  treatment    String?
  prescription String?
  status       RecordStatus @default(ACTIVE)
  visitDate    DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  patient  Patient    @relation(fields: [patientId], references: [id])
  doctor   Doctor     @relation(fields: [doctorId], references: [id])
  hospital Hospital   @relation(fields: [hospitalId], references: [id])
  files    FileUpload[]

  @@map("medical_records")
}

model FileUpload {
  id           String   @id @default(uuid())
  recordId     String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  s3Key        String   @unique
  s3Bucket     String
  url          String?
  uploadedById String
  createdAt    DateTime @default(now())

  record MedicalRecord @relation(fields: [recordId], references: [id])

  @@map("file_uploads")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  hospitalId      String
  title           String
  reason          String
  type            AppointmentType   @default(CONSULTATION)
  status          AppointmentStatus @default(PENDING)
  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id])
  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  hospital Hospital @relation(fields: [hospitalId], references: [id])

  @@map("appointments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String?
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ShareLink {
  id          String          @id @default(uuid())
  patientId   String
  token       String          @unique @default(uuid())
  scope       String          @default("ALL")
  expiresAt   DateTime
  maxAccess   Int?
  accessCount Int             @default(0)
  status      ShareLinkStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@map("share_links")
}

model ShareGrant {
  id          String    @id @default(uuid())
  patientId   String
  grantedToId String
  scope       String    @default("ALL")
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  patient   Patient @relation("PatientGrants", fields: [patientId], references: [id])
  grantedTo User    @relation("GrantedTo", fields: [grantedToId], references: [id])

  @@map("share_grants")
}

model Visit {
  id           String      @id @default(uuid())
  patientId    String
  doctorId     String
  hospitalId   String
  departmentId String?
  reason       String
  startTime    DateTime    @default(now())
  endTime      DateTime?
  status       VisitStatus @default(IN_PROGRESS)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  hospital      Hospital       @relation(fields: [hospitalId], references: [id])
  department    Department?    @relation(fields: [departmentId], references: [id])
  encounters    Encounter[]
  prescriptions Prescription[]
  labOrders     LabOrder[]

  @@map("visits")
}

model Encounter {
  id             String   @id @default(uuid())
  visitId        String
  chiefComplaint String?
  examination    String?
  diagnosis      String?
  notes          String?
  vitalSigns     Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("encounters")
}

model Prescription {
  id           String             @id @default(uuid())
  patientId    String
  doctorId     String
  hospitalId   String
  visitId      String?
  drug         String
  dosage       String
  frequency    String
  duration     String
  instructions String?
  status       PrescriptionStatus @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  patient  Patient  @relation(fields: [patientId], references: [id])
  doctor   Doctor   @relation(fields: [doctorId], references: [id])
  hospital Hospital @relation(fields: [hospitalId], references: [id])
  visit    Visit?   @relation(fields: [visitId], references: [id])

  @@map("prescriptions")
}

model LabOrder {
  id         String         @id @default(uuid())
  patientId  String
  doctorId   String
  hospitalId String
  visitId    String?
  tests      String[]
  notes      String?
  status     LabOrderStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  patient  Patient     @relation(fields: [patientId], references: [id])
  doctor   Doctor      @relation(fields: [doctorId], references: [id])
  hospital Hospital    @relation(fields: [hospitalId], references: [id])
  visit    Visit?      @relation(fields: [visitId], references: [id])
  results  LabResult[]

  @@map("lab_orders")
}

model LabResult {
  id             String   @id @default(uuid())
  orderId        String
  testName       String
  value          String?
  unit           String?
  referenceRange String?
  isAbnormal     Boolean  @default(false)
  notes          String?
  reportFile     String?
  createdAt      DateTime @default(now())

  order LabOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("lab_results")
}
